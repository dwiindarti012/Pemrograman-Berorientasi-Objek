class Mahasiswa:
    def __init__(self, nama, nim):
        self.__nama = nama
        self.__nim = nim

    def getNama(self):
        return self.__nama
    
    def getNim(self):
        return self.__nim
    
    def setNama(self, nama):
        self.__nama = nama
    
    def setNim(self, nim):
        self.__nim = nim


jumlah_mhs_ti = int(input("Masukkan jumlah mahasiswa: "))
mahasiswa_ti = []

for i in range(jumlah_mhs_ti):
    nama = input(f"Masukkan Nama ke-{i+1}: ")
    nim = int(input(f"Masukkan Nim ke-{i+1}: "))

    mhs_ti = Mahasiswa(nama, nim)

    mahasiswa_ti.append(mhs_ti)

for mhs in mahasiswa_ti:
    print ("Nama:", mhs.getNama())
    print ("Nim:", mhs.getNim())


cari_nama = input("Masukkan nama yang di cari: ")
for mhs in mahasiswa_ti:
    if (cari_nama == mhs.getNama()):
        mhs.setNama("Haura")
        print("Nama mahasiswa setelah diubah: ", mhs.getNama())
        print("Nim mahasiswa setelah diubah: ", mhs.getNim())
